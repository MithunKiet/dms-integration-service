# Application
APP_NAME=DMS Integration Service
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
LOG_DIR=logs

# Database Connections
HMIS_CONNECTION=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost,1433;DATABASE=HMIS_DB;UID=sa;PWD=YOUR_PASSWORD;TrustServerCertificate=yes;Encrypt=yes;Connection Timeout=600;
DMS_CONNECTION=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost,1433;DATABASE=DMS_DB;UID=sa;PWD=YOUR_PASSWORD;TrustServerCertificate=yes;Encrypt=yes;Connection Timeout=600;
INTEGRATION_CONNECTION=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost,1433;DATABASE=INTEGRATION_DB;UID=sa;PWD=YOUR_PASSWORD;TrustServerCertificate=yes;Encrypt=yes;Connection Timeout=600;

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Scheduler
SCHEDULER_TIMEZONE=UTC
JOB_MAX_INSTANCES=1
JOB_COALESCE=true
JOB_MISFIRE_GRACE_TIME=300

# Queue Poller
QUEUE_POLL_INTERVAL=10
QUEUE_MAX_CONCURRENT=3

# Retry
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=30

# Security
REQUIRE_HTTPS=false
API_KEYS_ENABLED=true
